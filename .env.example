# ==================== LLM (OpenAI 兼容) ====================
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ==================== Qdrant ====================
# local 模式: 数据存储在 QDRANT_LOCAL_PATH
# remote 模式: 连接 QDRANT_HOST:QDRANT_PORT
QDRANT_MODE=remote
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0

# ==================== Embedding ====================
EMBEDDING_DEVICE=cpu

# ==================== Retrieval ====================
DENSE_CONFIDENCE_THRESHOLD=0.3
RERANKER_CONFIDENCE_THRESHOLD=0.1

# ==================== API Auth (留空则跳过认证) ====================
API_KEY=
ADMIN_API_KEY=

# ==================== Logging ====================
LOG_LEVEL=INFO
